{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "n0ne",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.n0ne",
          "match": "#.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.n0ne",
          "match": "\\b(if|else|elif|while|for|break|continue|return|defer|guard)\\b"
        },
        {
          "name": "keyword.declaration.n0ne",
          "match": "\\b(fn|task|type|enum|const)\\b"
        },
        {
          "name": "constant.language.n0ne",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.n0ne",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.n0ne",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.n0ne",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.n0ne",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.n0ne",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.n0ne",
          "match": "\\b\\d+\\b"
        }
      ]
    }
  ],
  "scopeName": "source.n0ne"
}
